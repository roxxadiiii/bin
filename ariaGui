#!/bin/bash

# ASCII Art Banner
BANNER='
╔═╗┬─┐┬┌─┐              
╠═╣├┬┘│├─┤              
╩ ╩┴└─┴┴ ┴              
╔╦╗┌─┐┬ ┬┌┐┌┬  ┌─┐┌─┐┌┬┐
 ║║│ ││││││││  │ │├─┤ ││
═╩╝└─┘└┴┘┘└┘┴─┘└─┘┴ ┴─┴┘
╔╦╗┌─┐┌┐┌┌─┐┌─┐┌─┐┬─┐   
║║║├─┤│││├─┤│ ┬├┤ ├┬┘   
╩ ╩┴ ┴┘└┘┴ ┴└─┘└─┘┴└─   

          By: GITHUB/roxxadiiii
'

# Configuration
DOWNLOAD_DIR="$HOME/Downloads/aria2"
CONFIG_DIR="$HOME/.config/aria2-manager"
SESSION_FILE="$CONFIG_DIR/session.txt"
CONFIG_FILE="$CONFIG_DIR/aria2.conf"
BATCH_FILE="$CONFIG_DIR/batch_downloads.txt"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Create necessary directories
mkdir -p "$DOWNLOAD_DIR" "$CONFIG_DIR"

# Create default aria2 config if it doesn't exist
create_default_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" << EOF
# aria2 configuration
continue=true
max-connection-per-server=16
min-split-size=1M
split=16
max-concurrent-downloads=5
file-allocation=none
check-integrity=true
save-session=$SESSION_FILE
input-file=$SESSION_FILE
dir=$DOWNLOAD_DIR
EOF
        echo -e "${GREEN}Created default config at $CONFIG_FILE${NC}"
    fi
}

# Check if aria2c is installed
check_dependencies() {
    if ! command -v aria2c &> /dev/null; then
        echo -e "${RED}Error: aria2 is not installed!${NC}"
        echo "Install it with: sudo pacman -S aria2"
        exit 1
    fi
    
    if ! command -v gum &> /dev/null; then
        echo -e "${RED}Error: gum is not installed!${NC}"
        echo "Install it with: yay -S gum"
        exit 1
    fi
}

# Show current downloads
show_downloads() {
    echo -e "${CYAN}Current Downloads:${NC}"
    if pgrep -f "aria2c" > /dev/null; then
        echo -e "${GREEN}aria2c is running${NC}"
        if [ -f "$SESSION_FILE" ]; then
            echo "Active downloads:"
            cat "$SESSION_FILE" 2>/dev/null | head -10
        fi
    else
        echo -e "${YELLOW}No active downloads${NC}"
    fi
    echo ""
}

# Start aria2 daemon
start_daemon() {
    if pgrep -f "aria2c.*rpc-listen-port" > /dev/null; then
        echo -e "${YELLOW}aria2 daemon is already running${NC}"
        return
    fi
    
    echo -e "${BLUE}Starting aria2 daemon...${NC}"
    aria2c --enable-rpc --rpc-listen-all=true --rpc-allow-origin-all \
           --conf-path="$CONFIG_FILE" --daemon=true \
           --rpc-listen-port=6800 --rpc-secret="aria2-manager" \
           --log="$CONFIG_DIR/aria2.log" --log-level=warn
    
    sleep 2
    if pgrep -f "aria2c.*rpc-listen-port" > /dev/null; then
        echo -e "${GREEN}aria2 daemon started successfully${NC}"
    else
        echo -e "${RED}Failed to start aria2 daemon${NC}"
    fi
}

# Stop aria2 daemon
stop_daemon() {
    if pgrep -f "aria2c" > /dev/null; then
        echo -e "${BLUE}Stopping aria2...${NC}"
        pkill -f "aria2c"
        echo -e "${GREEN}aria2 stopped${NC}"
    else
        echo -e "${YELLOW}aria2 is not running${NC}"
    fi
}

# Add single download
add_download() {
    URL=$(gum input --prompt "Download URL> " --placeholder "https://example.com/file.zip")
    
    if [[ -z "$URL" ]]; then
        echo -e "${RED}URL cannot be empty!${NC}"
        return
    fi
    
    # Optional settings
    CUSTOM_DIR=$(gum input --prompt "Custom directory (optional)> " --placeholder "$DOWNLOAD_DIR")
    SPEED_LIMIT=$(gum input --prompt "Speed limit (optional, e.g., 1M, 500K)> " --placeholder "No limit")
    CONNECTIONS=$(gum input --prompt "Max connections (1-16)> " --placeholder "16")
    
    # Build aria2c command
    CMD="aria2c --conf-path=\"$CONFIG_FILE\""
    
    if [[ -n "$CUSTOM_DIR" ]]; then
        mkdir -p "$CUSTOM_DIR"
        CMD="$CMD --dir=\"$CUSTOM_DIR\""
    fi
    
    if [[ -n "$SPEED_LIMIT" ]]; then
        CMD="$CMD --max-download-limit=$SPEED_LIMIT"
    fi
    
    if [[ -n "$CONNECTIONS" && "$CONNECTIONS" =~ ^[0-9]+$ && "$CONNECTIONS" -le 16 && "$CONNECTIONS" -gt 0 ]]; then
        CMD="$CMD --max-connection-per-server=$CONNECTIONS --split=$CONNECTIONS"
    fi
    
    CMD="$CMD \"$URL\""
    
    echo -e "${BLUE}Starting download...${NC}"
    echo "Command: $CMD"
    
    # Execute download
    eval $CMD &
    
    echo -e "${GREEN}Download started in background${NC}"
}

# Batch download from file
batch_download() {
    if [ ! -f "$BATCH_FILE" ]; then
        echo -e "${YELLOW}Creating batch file template...${NC}"
        cat > "$BATCH_FILE" << EOF
# Add URLs one per line
# You can also add aria2 options after the URL
# Example:
# https://example.com/file1.zip
# https://example.com/file2.zip
#   dir=/custom/path
#   max-download-limit=1M
EOF
    fi
    
    echo -e "${BLUE}Opening batch file for editing...${NC}"
    echo "File location: $BATCH_FILE"
    
    if command -v nano &> /dev/null; then
        nano "$BATCH_FILE"
    elif command -v vim &> /dev/null; then
        vim "$BATCH_FILE"
    else
        echo "Please edit $BATCH_FILE manually"
        read -p "Press Enter when done..."
    fi
    
    # Count non-empty, non-comment lines
    URL_COUNT=$(grep -v '^#' "$BATCH_FILE" | grep -v '^[[:space:]]*$' | grep -c 'http')
    
    if [ "$URL_COUNT" -eq 0 ]; then
        echo -e "${YELLOW}No URLs found in batch file${NC}"
        return
    fi
    
    echo -e "${BLUE}Found $URL_COUNT URLs. Starting batch download...${NC}"
    
    aria2c --conf-path="$CONFIG_FILE" --input-file="$BATCH_FILE" &
    
    echo -e "${GREEN}Batch download started${NC}"
}

# Resume downloads
resume_downloads() {
    if [ -f "$SESSION_FILE" ]; then
        echo -e "${BLUE}Resuming previous downloads...${NC}"
        aria2c --conf-path="$CONFIG_FILE" &
        echo -e "${GREEN}Downloads resumed${NC}"
    else
        echo -e "${YELLOW}No previous session found${NC}"
    fi
}

# Monitor downloads
monitor_downloads() {
    echo -e "${CYAN}Download Monitor (press Ctrl+C to exit)${NC}"
    echo "=================================="
    
    while true; do
        clear
        echo "$BANNER"
        echo -e "${CYAN}Real-time Download Status:${NC}"
        echo "=================================="
        
        if pgrep -f "aria2c" > /dev/null; then
            # Show active processes
            ps aux | grep "[a]ria2c" | while read line; do
                echo -e "${GREEN}Active:${NC} aria2c process running"
                break
            done
            
            # Show download directory contents
            echo -e "\n${BLUE}Recent files in download directory:${NC}"
            ls -lht "$DOWNLOAD_DIR" 2>/dev/null | head -10
            
            # Show network usage (if available)
            if command -v nethogs &> /dev/null; then
                echo -e "\n${PURPLE}Network Usage:${NC}"
                timeout 2s nethogs -d 1 2>/dev/null | grep aria2 || echo "No aria2 network activity detected"
            fi
        else
            echo -e "${YELLOW}No active downloads${NC}"
        fi
        
        echo -e "\n${CYAN}Press Ctrl+C to return to main menu${NC}"
        sleep 3
    done
}

# Clean up completed downloads
cleanup() {
    echo -e "${BLUE}Cleaning up...${NC}"
    
    # Remove empty files
    find "$DOWNLOAD_DIR" -type f -empty -delete 2>/dev/null
    
    # Remove .aria2 control files for completed downloads
    find "$DOWNLOAD_DIR" -name "*.aria2" -type f | while read control_file; do
        original_file="${control_file%.aria2}"
        if [ -f "$original_file" ]; then
            rm "$control_file"
            echo -e "${GREEN}Cleaned up: $(basename "$control_file")${NC}"
        fi
    done
    
    echo -e "${GREEN}Cleanup completed${NC}"
}

# Configuration editor
edit_config() {
    echo -e "${BLUE}Current configuration:${NC}"
    cat "$CONFIG_FILE"
    echo ""
    
    if gum confirm "Edit configuration?"; then
        if command -v nano &> /dev/null; then
            nano "$CONFIG_FILE"
        elif command -v vim &> /dev/null; then
            vim "$CONFIG_FILE"
        else
            echo "Please edit $CONFIG_FILE manually"
        fi
        echo -e "${GREEN}Configuration updated${NC}"
    fi
}

# Main menu
main_menu() {
    while true; do
        clear
        echo "$BANNER"
        echo -e "${CYAN}What would you like to do?${NC}"
        
        show_downloads
        
        CHOICE=$(gum choose \
            "<> Add Single Download" \
            "<> Batch Download" \
            "<>  Resume Downloads" \
            "<> Monitor Downloads" \
            "<> Start Daemon" \
            "<> Stop Daemon" \
            "<> Cleanup Files" \
            "<>  Edit Config" \
            "<> Exit")
        
        case "$CHOICE" in
            "📥 Add Single Download")
                add_download
                read -p "Press Enter to continue..."
                ;;
            "📦 Batch Download")
                batch_download
                read -p "Press Enter to continue..."
                ;;
            "▶️  Resume Downloads")
                resume_downloads
                read -p "Press Enter to continue..."
                ;;
            "📊 Monitor Downloads")
                monitor_downloads
                ;;
            "🚀 Start Daemon")
                start_daemon
                read -p "Press Enter to continue..."
                ;;
            "🛑 Stop Daemon")
                stop_daemon
                read -p "Press Enter to continue..."
                ;;
            "🧹 Cleanup Files")
                cleanup
                read -p "Press Enter to continue..."
                ;;
            "⚙️  Edit Config")
                edit_config
                read -p "Press Enter to continue..."
                ;;
            "❌ Exit")
                echo -e "${GREEN}Thanks for using aria2 manager!${NC}"
                exit 0
                ;;
        esac
    done
}

# Quick mode for command line usage
if [ "$#" -gt 0 ]; then
    case "$1" in
        "add")
            if [ -n "$2" ]; then
                echo -e "${BLUE}Quick download: $2${NC}"
                aria2c --conf-path="$CONFIG_FILE" "$2" &
                echo -e "${GREEN}Download started${NC}"
            else
                echo "Usage: $0 add <URL>"
            fi
            ;;
        "daemon")
            start_daemon
            ;;
        "stop")
            stop_daemon
            ;;
        "status")
            show_downloads
            ;;
        "resume")
            resume_downloads
            ;;
        "clean")
            cleanup
            ;;
        *)
            echo "Usage: $0 [add URL|daemon|stop|status|resume|clean]"
            echo "Run without arguments for interactive mode"
            ;;
    esac
    exit 0
fi

# Initialize
check_dependencies
create_default_config

# Start interactive mode
main_menu
